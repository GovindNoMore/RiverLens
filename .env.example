# ─────────────────────────────────────────────
#  River Report Card — Environment Variables
# ─────────────────────────────────────────────

# Groq API key (free tier — no credit card needed)
# Get yours at: https://console.groq.com
VITE_GROQ_API_KEY=your_groq_api_key_here

# Model to use (fast + free on Groq's free tier)
VITE_GROQ_MODEL=llama-3.3-70b-versatile

# Data source label shown in UI
VITE_DATA_SOURCE=CPCB NWMP 2021
